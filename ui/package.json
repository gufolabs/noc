{
  "name": "noc-builder",
  "version": "1.0.0",
  "main": "index.js",
  "repository": {
    "type": "git",
    "url": "https://github.com/gufolabs/noc.git",
    "directory": "ui"
  },
  "config": {
    "defaultTheme": "noc",
    "defaultLanguage": "en"
  },
  "packageManager": "pnpm@10.18.3",
  "engines": {
    "node": "^24.0.0"
  },
  "overrides": {
    "js-yaml": "4.1.1",
    "lodash": ">=4.18.0",
    "rollup": ">=4.59.0",
    "immutable": "3.8.3",
    "flatted": ">=3.4.2",
    "socket.io-parser": ">=4.2.6",
    "monaco-editor": {
      "dompurify": ">=3.3.2"
    },
    "eslint": {
      "minimatch": "^3.1.4"
    },
    "resp-modifier": {
      "minimatch": "^3.1.4"
    },
    "@typescript-eslint/typescript-estree": {
      "minimatch": "^9.0.7"
    },
    "readdirp": {
      "picomatch": "^2.3.2"
    },
    "anymatch": {
      "picomatch": "^2.3.2"
    },
    "micromatch": {
      "picomatch": "^2.3.2"
    },
    "vitest": {
      "picomatch": ">=4.0.4"
    },
    "tinyglobby": {
      "picomatch": ">=4.0.4"
    },
    "minimatch@3": {
      "brace-expansion": "^1.1.13"
    },
    "minimatch@9": {
      "brace-expansion": "^2.0.3"
    }
  },
  "pnpm": {
    "overrides": {
      "js-yaml": "4.1.1",
      "dompurify": ">=3.3.2",
      "lodash": ">=4.18.0",
      "rollup": ">=4.59.0",
      "immutable": "3.8.3",
      "flatted": ">=3.4.2",
      "socket.io-parser": ">=4.2.6",
      "vite": ">=7.3.2",
      "eslint>minimatch": "^3.1.4",
      "resp-modifier>minimatch": "^3.1.4",
      "@typescript-eslint/typescript-estree>minimatch": "^9.0.7",
      "readdirp>picomatch": "^2.3.2",
      "anymatch>picomatch": "^2.3.2",
      "micromatch>picomatch": "^2.3.2",
      "vitest>picomatch": ">=4.0.4",
      "tinyglobby>picomatch": ">=4.0.4",
      "minimatch@3>brace-expansion": "^1.1.13",
      "minimatch@9>brace-expansion": "^2.0.3"
    }
  },
  "scripts": {
    "dev": "pnpm run clean && pnpm run vendor-dev && pnpm run build:bundles-dev && pnpm run watch",
    "watch": "node build.ts dev noc en",
    "watch:bundles": "node watch-bundles.ts",
    "prod": "node build.ts prod",
    "vendor": "node build.ts vendor",
    "vendor-dev": "node build.ts vendor-dev noc en",
    "sync": "browser-sync start --proxy 'localhost:8080' --files 'dist/**/*.js,dist/**/*.css,dist/**/*.html,dist/**/*.map' --no-open",
    "lint": "eslint scripts --fix",
    "clean": "rm -rf dist",
    "build": "pnpm run clean && pnpm run vendor && pnpm run prod && pnpm run build:bundles-prod",
    "build:micromark-dev": "node build-bundle.ts micromark --dev",
    "build:monaco-dev": "node build-bundle.ts monaco --dev",
    "build:leaflet-dev": "node build-bundle.ts leaflet --dev",
    "build:joint-dev": "node build-bundle.ts joint/index --dev",
    "build:topo-map": "cp node_modules/topo-map/dist/topo-map.umd.js dist/topo-map.umd.js",
    "build:bundles-dev": "pnpm run build:micromark-dev && pnpm run build:monaco-dev && pnpm run build:leaflet-dev && pnpm run build:joint-dev && pnpm run build:topo-map",
    "build:bundles-prod": "node build-bundles-prod.ts",
    "test": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:ui": "playwright test --ui",
    "update-npm-lock": "npm install --package-lock-only"
  },
  "author": "",
  "license": "ISC",
  "description": "",
  "type": "module",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.57.0",
    "@types/espree": "^10.1.0",
    "@types/estree": "^1.0.8",
    "@types/fs-extra": "^11.0.4",
    "@types/leaflet": "^1.9.21",
    "@types/node": "^24.12.0",
    "astring": "^1.9.0",
    "browser-sync": "^3.0.4",
    "esbuild": "^0.27.2",
    "eslint": "^10.2.0",
    "espree": "^10.4.0",
    "estree-walker": "^3.0.3",
    "fs-extra": "^11.3.2",
    "globals": "^16.5.0",
    "magic-string": "^0.30.21",
    "playwright": "^1.57.0",
    "source-map": "^0.7.6",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.58.0",
    "vite": "8.0.6",
    "vitest": "^4.1.3"
  },
  "dependencies": {
    "@gufo-labs/font": "^0.0.9",
    "@joint/core": "^4.2.4",
    "color-input": "github:argyleink/css-color-component#cdn-latest",
    "dompurify": "^3.3.3",
    "leaflet": "^1.9.4",
    "micromark": "^4.0.2",
    "micromark-extension-gfm": "^3.0.0",
    "monaco-editor": "^0.55.1",
    "topo-map": "github:uncol/topo-map",
    "ymaps": "^0.2.1"
  }
}